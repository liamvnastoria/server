{
  "name": "server",
  "version": "1.0.0",
  "description": "A sample server project",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "start": "node index.js", 
    "dev": "nodemon index.js", 
    "build:electron": "electron-packager . server --platform=win32 --arch=x64",
    "start:electron": "electron .",
    "docker:build": "docker build -t server .", 
    "docker:run": "docker run -p 3000:3000 server", 
    "lint": "eslint .",
    "format": "prettier --write .",
    "clean": "rimraf dist", 
    "prepare": "husky install", 
    "install:all": "npm install && npm run build:electron && npm run docker:build",
    "install:frontend": "npm install --prefix frontend",
    "install:backend": "npm install --prefix backend"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liamvnastoria/server.git"
  },
  "keywords": ["server", "nodejs"],
  "author": "Liam Von Astoria",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/liamvnastoria/server/issues"
  },
  "homepage": "https://github.com/liamvnastoria/server#readme",
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.0",
    "eslint": "^9.35.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0", 
    "husky": "^8.0.0",
    "electron": "^26.0.0",
    "electron-packager": "^17.0.0" 
  }
}